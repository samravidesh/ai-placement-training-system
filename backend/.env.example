PORT=5000

DB_CLIENT=prisma
NEON_DATABASE_URL=postgresql://username:password@ep-example-123456.us-east-2.aws.neon.tech/placement_training?sslmode=require
# Optional: set DATABASE_URL to the same Neon URL if you use tools that expect this name.
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=placement_training
DB_SSL=false

JWT_SECRET=your_strong_secret_here
JWT_EXPIRES_IN=1d

AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_ENABLED=true
RAG_MAX_RETRIEVED_DOCS=12
RAG_SYNC_ON_REQUEST=false

ADMIN_EMAILS=admin@example.com
